    "disabilityRules": [
        {
            "when": {
                "geo": "1d"
            },
            "disable": {
                "grav": [
                    "on"
                ],
                "rock": [
                    "layer"
                ],
                "well": [
                    "center",
                    "offctr"
                ]
            }
        },
        {
            "when": {
                "geo": "2dxz"
            },
            "disable": {
                "well": [
                    "corner",
                    "center",
                    "offctr"
                ]
            },
            "note": "2D XZ implies side-to-side flooding"
        },
        {
            "when": {
                "mode": "wf"
            },
            "disable": {
                "geo": [
                    "2dxy",
                    "3d"
                ]
            },
            "reason": "Use Simulation for areal/3D flooding"
        },
        {
            "when": {
                "mode": "wf",
                "geo": "1d"
            },
            "disable": {
                "well": [
                    "corner",
                    "center",
                    "offctr"
                ]
            }
        },
        {
            "when": {
                "mode": "dep"
            },
            "disable": {
                "well": [
                    "e2e"
                ],
                "geo": [
                    "2dxz"
                ]
            }
        },
        {
            "when": {
                "mode": "sim",
                "geo": "1d"
            },
            "disable": {}
        },
        {
            "when": {
                "rock": "uni"
            },
            "disable": {},
            "note": "Always allowed"
        },
        {
            "when": {
                "geo": [
                    "2dxz",
                    "2dxy",
                    "3d"
                ]
            },
            "disable": {
                "grid": [
                    "12",
                    "24",
                    "48",
                    "96"
                ],
                "dt": [
                    "5d",
                    "1d",
                    "025d"
                ]
            },
            "note": "Pragmatic limits: run varying grid/dt only on 1D"
        }
    ],
