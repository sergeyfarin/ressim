+    // Observation-only diagnostic for the matrix-free StandardWell path. `wellOperator` is the
+    // same -C D^-1 B operator passed to system_cpr; it is applied to scalar basis vectors only
+    // to write the materialized matrix. The matrix/operator used by the actual solve are not
+    // modified.
+    template <class SimulatorType, class MatrixType, class VectorType, class WellOperator,
+              class Communicator>
+    void writeMaterializedMatrix(const SimulatorType& simulator,
+                                 const MatrixType& matrix,
+                                 const WellOperator& wellOperator,
+                                 const std::string& sysName,
+                                 [[maybe_unused]] const Communicator* comm)
+    {
+        using Block = typename MatrixType::block_type;
+        using Scalar = typename Block::field_type;
+        constexpr std::size_t block_rows = Block::rows;
+        constexpr std::size_t block_cols = Block::cols;
+        static_assert(block_rows == block_cols,
+                      "materialized MatrixMarket diagnostic requires square blocks");
+
+        using Entry = std::pair<std::size_t, std::size_t>;
+        std::map<Entry, Scalar> entries;
+        for (std::size_t block_row = 0; block_row < matrix.N(); ++block_row) {
+            for (const auto& block_entry : matrix[block_row]) {
+                const auto block_col = block_entry.index();
+                for (std::size_t row = 0; row < block_rows; ++row) {
+                    for (std::size_t col = 0; col < block_cols; ++col) {
+                        const auto value = block_entry[row][col];
+                        if (value != Scalar{0}) {
+                            entries[{block_rows * block_row + row,
+                                     block_cols * block_col + col}] += value;
+                        }
+                    }
+                }
+            }
+        }
+
+        // Do not reuse or alter the live matrix. The well operator is local and sparse, but
+        // applying it to a basis makes its matrix-free StandardWell contribution observable.
+        VectorType basis(matrix.N());
+        VectorType well_column(matrix.N());
+        for (std::size_t block_col = 0; block_col < matrix.N(); ++block_col) {
+            for (std::size_t col = 0; col < block_cols; ++col) {
+                basis = Scalar{0};
+                basis[block_col][col] = Scalar{1};
+                well_column = Scalar{0};
+                wellOperator.apply(basis, well_column);
+                for (std::size_t block_row = 0; block_row < matrix.N(); ++block_row) {
+                    for (std::size_t row = 0; row < block_rows; ++row) {
+                        const auto value = well_column[block_row][row];
+                        if (value != Scalar{0}) {
+                            entries[{block_rows * block_row + row,
+                                     block_cols * block_col + col}] += value;
+                        }
+                    }
+                }
+            }
+        }
+
+        namespace fs = std::filesystem;
+        const auto output_dir = fs::path{simulator.problem().outputDir()} / "reports";
+        if (!fs::exists(output_dir)) {
+            fs::create_directory(output_dir);
+        }
+        const auto& iterCtx = simulator.problem().iterationContext();
+        std::ostringstream name;
+        name << "prob_" << simulator.episodeIndex()
+             << "_time_" << std::setprecision(15) << std::setw(12) << std::setfill('0')
+             << simulator.time() << "_nit_" << iterCtx.iteration()
+             << '_' << sysName << "materialized_matrix_istl.mm";
+        std::ofstream output{output_dir / name.str()};
+        if (!output) {
+            throw std::ios_base::failure("open materialized MatrixMarket diagnostic");
+        }
+        output << "%%MatrixMarket matrix coordinate real general\n"
+               << block_rows * matrix.N() << ' ' << block_cols * matrix.M() << ' '
+               << entries.size() << '\n';
+        output << std::setprecision(17);
+        for (const auto& [index, value] : entries) {
+            output << index.first + 1 << ' ' << index.second + 1 << ' ' << value << '\n';
+        }
+    }
+
