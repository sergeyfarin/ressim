 namespace Opm {
 
+namespace ResSimTpfaPartitionTrace {
+
+inline int targetCell()
+{
+    static const int target = [] {
+        const char* raw = std::getenv("OPM_RESSIM_PARTITION_CELL");
+        return raw ? std::atoi(raw) : -1;
+    }();
+    return target;
+}
+
+template<class Simulator, class Vector>
+void write(const Simulator& simulator,
+           unsigned cell,
+           const char* term,
+           int neighbor,
+           const Vector& values)
+{
+    const char* path = std::getenv("OPM_RESSIM_PARTITION_FILE");
+    if (!path || targetCell() < 0 || cell != static_cast<unsigned>(targetCell())) {
+        return;
+    }
+
+    static std::mutex mutex;
+    std::lock_guard<std::mutex> guard(mutex);
+    std::ofstream out(path, std::ios::app);
+    out << std::setprecision(17)
+        << "OPM-RESERVOIR-PARTITION"
+        << " time_s=" << simulator.time()
+        << " dt_s=" << simulator.timeStepSize()
+        << " iteration=" << simulator.problem().iterationContext().iteration()
+        << " cell=" << cell
+        << " term=" << term
+        << " neighbor=" << neighbor;
+    for (unsigned eqIdx = 0; eqIdx < values.size(); ++eqIdx) {
+        out << " eq" << eqIdx << '=' << values[eqIdx];
+    }
+    out << '\n';
+}
+
