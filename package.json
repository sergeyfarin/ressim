{
  "name": "ressim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build:wasm",
    "dev": "vite --host",
    "prebuild": "npm run build:wasm",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "sh scripts/build-wasm.sh",
    "validate": "npm run typecheck && npm run lint && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --max-warnings=0",
    "test:rust:impes": "bash scripts/validate-solver-coverage.sh impes",
    "validate:product": "npm run typecheck && npm run lint && npm test && npm run test:rust:impes && npm run build",
    "opm:deck": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli generate-deck",
    "opm:artifacts": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli build-artifacts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/three": "0.184.1",
    "@typescript-eslint/parser": "^8.59.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@vitest/coverage-v8": "^4.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "svelte": "^5.55.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "three": "0.184.0"
  }
}
