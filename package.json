{
  "name": "ressim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm run build:wasm",
    "dev": "vite --host",
    "prebuild": "pnpm run build:wasm",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "sh scripts/build-wasm.sh",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --max-warnings=0",
    "test:rust:impes": "bash scripts/validate-solver-coverage.sh impes",
    "validate:product": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run test:rust:impes && pnpm run build",
    "opm:deck": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli generate-deck",
    "opm:artifacts": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli build-artifacts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.0",
    "@types/three": "0.185.0",
    "@typescript-eslint/parser": "8.62.1",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.2",
    "eslint": "10.6.0",
    "eslint-plugin-svelte": "3.20.0",
    "svelte": "5.56.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "three": "0.185.1"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
