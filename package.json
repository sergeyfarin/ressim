{
  "name": "ressim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm run build:wasm",
    "dev": "vite --host",
    "prebuild": "pnpm run build:wasm",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "sh scripts/build-wasm.sh",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --max-warnings=0",
    "test:rust:impes": "bash scripts/validate-solver-coverage.sh impes",
    "validate:product": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run test:rust:impes && pnpm run build",
    "opm:deck": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli generate-deck",
    "opm:artifacts": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli build-artifacts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/three": "0.185.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "eslint": "10.7.0",
    "eslint-plugin-svelte": "3.20.0",
    "svelte": "5.56.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "three": "0.185.1"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
