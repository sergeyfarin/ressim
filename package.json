{
  "name": "ressim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm run build:wasm",
    "dev": "vite --host",
    "prebuild": "pnpm run build:wasm",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "sh scripts/build-wasm.sh",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run check:cycles && pnpm test && pnpm run build",
    "typecheck": "tsc --noEmit",
    "check:cycles": "node scripts/check-import-cycles.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --max-warnings=0",
    "test:rust:impes": "bash scripts/validate-solver-coverage.sh impes",
    "validate:product": "pnpm run typecheck && pnpm run lint && pnpm run check:cycles && pnpm test && pnpm run test:rust:impes && pnpm run build",
    "opm:deck": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli generate-deck",
    "opm:artifacts": "uv run --directory tools/opm_flow python -m opm_flow_tool.cli build-artifacts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "26.1.1",
    "@types/three": "0.185.1",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.4",
    "eslint": "10.7.0",
    "eslint-plugin-svelte": "3.22.0",
    "svelte": "5.56.7",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "three": "0.185.1"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
