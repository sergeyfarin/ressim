{
  "name": "ressim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build:wasm",
    "dev": "vite",
    "prebuild": "npm run build:wasm",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "sh scripts/build-wasm.sh",
    "validate": "npm run typecheck && npm run lint && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --max-warnings=0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/three": "0.183.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "svelte": "^5.55.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "three": "0.183.2"
  }
}
